# ============================================================================
# FastAPI backend — environment variables (copy to backend/.env, never commit)
# ============================================================================

# --- Core ---
ENVIRONMENT=development                 # development | production
FRONTEND_ORIGIN=http://localhost:5173   # React dev server (CORS allowlist)
SESSION_SECRET=change-me-long-random    # signs session cookies

# --- Master encryption key (Tier-1 secret) ---
# Encrypts per-client credentials at rest. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In production this comes from a Secret Manager, NOT this file.
CREDENTIAL_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# --- Database ---
# Local: docker postgres, or Neon/Supabase/Railway connection string
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/growth_analyst

# --- Google OAuth (employee login gate) ---
AUTH_ALLOWED_DOMAIN=schbang.com
AUTH_GOOGLE_CLIENT_ID=XXXX.apps.googleusercontent.com
AUTH_GOOGLE_CLIENT_SECRET=GOCSPX-XXXX
AUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# --- AI narrative engines (Tier-1 secrets) ---
GEMINI_API_KEY=AIzaSy...
XAI_API_KEY=xai-...

# --- Optional data sources ---
GOOGLE_PAGESPEED_API_KEY=
CLARITY_API_TOKEN=

# serper.dev — live Google SERP checks for the Uplift Tracker module (optional)
SERPER_API_KEY=
SERPER_GL=in
# Starting serper credit balance, so the profile shows "credits remaining"
SERPER_CREDIT_BALANCE=2500
