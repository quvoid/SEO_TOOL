# =============================================================================
# AI Growth Analyst — Secrets Template
# =============================================================================
# 1. LOCAL DEV:  Copy this file to  .streamlit/secrets.toml  and fill in values.
# 2. CLOUD RUN:  Set each value as an environment variable (AUTH_GOOGLE_CLIENT_ID etc.)
#               OR mount a secrets.toml via Cloud Run Secret Manager.
# 3. STREAMLIT CLOUD: Paste contents into App → ⋮ → Settings → Secrets.
#
# ⚠️  NEVER commit the real secrets.toml to git. It is already in .gitignore.
# ⚠️  NEVER put real credentials in THIS file — it is tracked by git.
# =============================================================================

# ── AI narrative engine (Gemini) ─────────────────────────────────────────────
[gemini]
api_key = "AIzaSy..."

# ── Google OAuth 2.0 — employee login gate ───────────────────────────────────
# GCP Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Application type: Web application
# Authorised redirect URIs:
#   http://localhost:8501          (local dev)
#   https://analytics.schbang.com  (production)
[auth]
allowed_domain       = "schbang.com"
google_client_id     = "XXXX.apps.googleusercontent.com"
google_client_secret = "GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXX"
redirect_uri         = "http://localhost:8501"

# ── GCP Service Account — GA4 + Search Console (Option A) ────────────────────
[gcp_service_account]
type                        = "service_account"
project_id                  = "your-gcp-project-id"
private_key_id              = "key-id-hex"
private_key                 = "-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"
client_email                = "growth-analyst@your-project.iam.gserviceaccount.com"
client_id                   = "1234567890"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "https://www.googleapis.com/robot/v1/metadata/x509/growth-analyst%40your-project.iam.gserviceaccount.com"
universe_domain             = "googleapis.com"

# ── User OAuth Credentials — GA4 + Search Console (Option B) ─────────────────
# Run generate_ga4_gsc_token.py once to get these credentials.
[user_oauth]
client_id     = "XXXX.apps.googleusercontent.com"
client_secret = "GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXX"
refresh_token = "1//XXXXXXXXXXXXXX-REPLACE_WITH_OUTPUT_OF_generate_ga4_gsc_token"

# ── Microsoft Clarity (optional) ─────────────────────────────────────────────
[clarity]
api_token = "CLARITY_DATA_EXPORT_TOKEN"
