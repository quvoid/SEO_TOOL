# AI Growth Analyst — Environment variables reference
# Used when deploying to Cloud Run (set these as Cloud Run env vars or Secret Manager)
# For local dev, use .streamlit/secrets.toml instead.

ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

AUTH_ALLOWED_DOMAIN=schbang.com
AUTH_GOOGLE_CLIENT_ID=XXXX.apps.googleusercontent.com
AUTH_GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXX
AUTH_REDIRECT_URI=https://analytics.schbang.com   # your production URL

GOOGLE_ADS_DEVELOPER_TOKEN=REPLACE_ME
GOOGLE_ADS_CLIENT_ID=XXXX.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=GOCSPX-XXXXXXXXXX
GOOGLE_ADS_REFRESH_TOKEN=1//XXXXXX
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# GCP service account: set via mounted secrets.toml on Cloud Run
# OR use Workload Identity Federation (recommended for production)
